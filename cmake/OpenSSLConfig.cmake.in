@PACKAGE_INIT@

set(_openssl_shim_openssl_version "@OPENSSL_SHIM_OPENSSL_VERSION@")

# openssl-shim only models OpenSSL 3.x semantics.
if(DEFINED OpenSSL_FIND_VERSION_MAJOR AND OpenSSL_FIND_VERSION_MAJOR LESS 3)
  if(OpenSSL_FIND_REQUIRED)
    message(FATAL_ERROR
      "openssl-shim provides OpenSSL ${_openssl_shim_openssl_version}; "
      "requested OpenSSL ${OpenSSL_FIND_VERSION} is below major version 3")
  endif()
  set(OpenSSL_FOUND FALSE)
  set(OPENSSL_FOUND FALSE)
  return()
endif()

if(DEFINED OpenSSL_FIND_VERSION)
  if(OpenSSL_FIND_VERSION_EXACT)
    if(NOT _openssl_shim_openssl_version VERSION_EQUAL OpenSSL_FIND_VERSION)
      if(OpenSSL_FIND_REQUIRED)
        message(FATAL_ERROR
          "openssl-shim provides OpenSSL ${_openssl_shim_openssl_version}; "
          "exact OpenSSL ${OpenSSL_FIND_VERSION} requested")
      endif()
      set(OpenSSL_FOUND FALSE)
      set(OPENSSL_FOUND FALSE)
      return()
    endif()
  elseif(_openssl_shim_openssl_version VERSION_LESS OpenSSL_FIND_VERSION)
    if(OpenSSL_FIND_REQUIRED)
      message(FATAL_ERROR
        "openssl-shim provides OpenSSL ${_openssl_shim_openssl_version}; "
        "OpenSSL ${OpenSSL_FIND_VERSION} requested")
    endif()
    set(OpenSSL_FOUND FALSE)
    set(OPENSSL_FOUND FALSE)
    return()
  endif()
endif()

get_filename_component(_openssl_prefix "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

include(CMakeFindDependencyMacro)
if("@OPENSSL_SHIM_EFFECTIVE_BACKEND@" STREQUAL "MBEDTLS")
  find_dependency(MbedTLS 3...<4)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/OpenSSLShimTargets.cmake")

set(OpenSSL_FOUND TRUE)
set(OPENSSL_FOUND TRUE)
set(OPENSSL_VERSION "${_openssl_shim_openssl_version}")
set(OpenSSL_VERSION "${_openssl_shim_openssl_version}")

set(OPENSSL_INCLUDE_DIR "${_openssl_prefix}/@CMAKE_INSTALL_INCLUDEDIR@")
set(OPENSSL_LIBRARIES OpenSSL::SSL OpenSSL::Crypto)
